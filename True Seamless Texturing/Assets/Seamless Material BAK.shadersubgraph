    "m_SourceType": 1,
    "m_FunctionName": "RandomiseScaling",
    "m_FunctionSource": "",
    "m_FunctionBody": "// Remap cells input from 0-1 to scaling min max\n// Remap simplified from:\n// Out = OutMinMax.x + (In - InMinMax.x) * (OutMinMax.y - OutMinMax.x) / (InMinMax.y - InMinMax.x);\n\nif (!Enabled) {\n\tOut = 1;\n\treturn;\n}\n\nOut = OutMinMax.x + (Cells - 0) * (OutMinMax.y - OutMinMax.x) / (1 - 0);"
}

