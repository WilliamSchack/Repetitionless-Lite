    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "ScaleEdgeUVTiling",
    "m_FunctionSource": "",
    "m_FunctionBody": "// Gets the average of ScalingMinMax\n// Sets to abs(minMaxAverage.x) if average is 0\n\nif (!Enabled) {\n\tOut = 1;\n\treturn;\n}\n\nfloat minMaxAverage = (ScalingMinMax.x + ScalingMinMax.y) / 2;\nOut = minMaxAverage;"
}

