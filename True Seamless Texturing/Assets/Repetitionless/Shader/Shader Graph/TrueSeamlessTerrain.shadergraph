    "m_Title": "Settings (int)",
    "m_Content": "> Noise Enabled                                 = (value & 1) != 0\n> Randomise Scaling                          = (value & 2) != 0\n> Randomise Rotation                        = (value & 4) != 0\n> Variation Enabled                            = (value & 8) != 0\n> Override Distance Blend Min/Max = (value & 16) != 0\n> Override Distance Blend TO           = (value & 32) != 0",
    "m_TextSize": 0,
    "m_Theme": 0,
