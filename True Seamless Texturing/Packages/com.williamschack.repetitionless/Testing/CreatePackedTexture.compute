#pragma kernel CSMain

uint Width;
uint Height;

int4 Channels;

int4 AssignedTextures;

Texture2D<float4> RTex;
Texture2D<float4> GTex;
Texture2D<float4> BTex;
Texture2D<float4> ATex;

RWTexture2D<float4> Result;

[numthreads(8, 8, 1)]
void CSMain (uint3 id : SV_DispatchThreadID)
{
    // Assumes all textures have the same dimensions, but exit here if not
    if (id.x >= Width || id.y >= Height)
        return;
    
    half r = AssignedTextures[0] == 1 ? RTex[id.xy][Channels[0]] : RTex[float2(0, 0)];
    half g = AssignedTextures[1] == 1 ? GTex[id.xy][Channels[1]] : GTex[float2(0, 0)];
    half b = AssignedTextures[2] == 1 ? BTex[id.xy][Channels[2]] : BTex[float2(0, 0)];
    half a = AssignedTextures[3] == 1 ? ATex[id.xy][Channels[3]] : ATex[float2(0, 0)];

    Result[id.xy] = float4(r, g, b, a);
}